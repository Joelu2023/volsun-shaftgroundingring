# Dev（可选）：本机局域网 IP 或 127.0.0.1 若与 next.config 默认列表不一致，可在此追加 hostname，逗号分隔
# 例：ALLOWED_DEV_ORIGINS=192.168.0.105,10.0.0.12
ALLOWED_DEV_ORIGINS=

# Site
#
# Production 必填：用于 canonical / JSON-LD / OG 的 url 字段
# 建议：测试环境也尽量填真实域名（不要留空或用 localhost）
NEXT_PUBLIC_SITE_URL=https://your-domain.com
# 前台对外展示邮箱（Header/Contact/表单错误提示等）；建议与内部收件邮箱分离
NEXT_PUBLIC_SITE_EMAIL=info@szvolsun.com

# Resource Center Phase 1
DATABASE_URL=
RC_BOOTSTRAP_ADMIN_PASSWORD=
RC_DB_ENABLED=false
RC_DB_READ_ENABLED=false
RC_AUTH_DB_ENABLED=false

# Resource Center Phase 5 storage provider
# Step 1 only reserves provider configuration. Uploads still use local storage until later steps wire provider selection.
RC_STORAGE_PROVIDER=local
RC_OBJECT_STORAGE_ENDPOINT=
RC_OBJECT_STORAGE_BUCKET=
RC_OBJECT_STORAGE_REGION=
RC_OBJECT_STORAGE_ACCESS_KEY_ID=
RC_OBJECT_STORAGE_SECRET_ACCESS_KEY=
RC_OBJECT_STORAGE_PUBLIC_BASE_URL=

# Optional: override default Hero image (default in code: /images/home/home-hero-motor-application-01.webp.jpg)
NEXT_PUBLIC_HERO_IMAGE=

# Inquiry email (SMTP) — 生产环境必填；/api/inquiries 校验通过后发信
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# 防呆：若 SMTP_PASS / 客户端授权码中包含 #、空格、&、= 或其他特殊字符，必须使用双引号包裹
# 示例：SMTP_PASS="your_authorization_code_with_#_or_special_chars"
# 465 常用 true（SSL），587 常用 false（STARTTLS）
SMTP_SECURE=false
# 询盘内部收件人，可多个邮箱，使用英文逗号分隔
INQUIRY_EMAIL_TO=
# 系统发件邮箱（建议与 SMTP_USER 一致）
INQUIRY_EMAIL_FROM=

# 开发专用（仅 non-production 生效）：true 时询盘仍会先写入 JSONL，再写 smtp_skipped 终态并跳过 SMTP
# 生产构建（NODE_ENV=production）下此开关无效，生产仍会尝试 SMTP（询盘始终先写入 .data/inquiries.jsonl）
INQUIRY_DEV_ACCEPT_WITHOUT_SMTP=

# Resource center admin users
# Example:
# RESOURCE_CENTER_USERS=[{"username":"admin","password":"change-me","role":"admin"},{"username":"editor","password":"change-me-too","role":"editor"}]
RESOURCE_CENTER_USERS=
RESOURCE_CENTER_SESSION_SECRET=
